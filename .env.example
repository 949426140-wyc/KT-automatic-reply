NODE_ENV=production
PORT=3000

# AI 路由：LLM Wiki 负责本地检索，DeepSeek 只负责基于证据组织语言
AI_PROVIDER=deepseek
AI_API_KEY=
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat

# 卡帕西式 LLM Wiki（本地 Markdown 编译知识层）
LLM_WIKI_ENABLED=true
LLM_WIKI_STRICT=true
LLM_WIKI_ROOT=/app/knowledge/LLM-Wiki
LLM_WIKI_MAX_PAGES=6
LLM_WIKI_MIN_SCORE=18

# 钉钉 Stream 机器人
DINGTALK_CONNECT_MODE=stream
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_ROBOT_CODE=
DINGTALK_STREAM_DEBUG=false

# 机器人策略
BOT_GROUP_ONLY_AT=true
BOT_MAX_MESSAGE_AGE_MIN=5
BOT_SKIP_EMPLOYEE_SENDERS=false
BOT_AUDIT_LOG_FILE=/app/data/bot-reply-audit.jsonl
RUNTIME_DIR=/app/runtime
CONVERSATION_CONTEXT_TTL_MIN=30
CONVERSATION_CONTEXT_MAX_MESSAGES=16

# 企业微信客服测试（默认关闭：完成公网 HTTPS 回调验证和人工试发前，不会读取或发送任何企业微信消息）
WECOM_KF_ENABLED=false
WECOM_KF_AUTO_SEND=false
WECOM_KF_CORP_ID=
WECOM_KF_SECRET=
WECOM_KF_CALLBACK_TOKEN=
WECOM_KF_CALLBACK_AES_KEY=

# 自动回复边界
ENABLE_GROUP_REPLIES=true
ENABLE_DIRECT_REPLIES=true
RELAXED_DIRECT_REPLIES=true
MAX_HISTORY_ROUNDS=5
SKIP_SELF=true
FILTER_EMPLOYEE_SENDERS=false
FILTER_HQ_SENDERS=false
RATE_LIMIT_SEC=60
DIRECT_RATE_LIMIT_SEC=2
GROUP_RATE_LIMIT_SEC=2
RECENT_MESSAGE_WINDOW_MIN=5
SEMI_AUTO_MODE=false
PENDING_REVIEW_MODE=true
PENDING_QUEUE_MAX_ITEMS=300

# 钉钉个人号轮询稳定性
DWS_RETRIES=2
DWS_AUTH_ERROR_PAUSE_MIN=1440
DWS_GROUP_AUTH_BLOCK_MIN=10080
DWS_MAX_CONSECUTIVE_FAILURES=12

# 视觉模型（等提供参数后填写）
ENABLE_VISION_RECOGNITION=false
DOUBAO_VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VISION_MODEL=doubao-seed-2-0-code-preview-260215
DOUBAO_VISION_API_KEY=
DOUBAO_VISION_TIMEOUT_SEC=60
DOUBAO_VISION_MAX_TOKENS=800

# 可选路径（服务器内默认使用 /app 与挂载目录）
PRODUCT_KB_ROOT=/app/product-source
PRODUCT_MATRIX_DIR=/app/product-source/01_MD章节矩阵
PRODUCT_DATA_DIR=/app/product-source/05_数据与图片
IMAGE_LIBRARY_ROOT=/app/images
AI_PLANNER_SOURCE_DIR=/app/knowledge
HQ_USER_TABLE_FILE=
